{
  "$schema": "https://raw.githubusercontent.com/nicoschmitt/tauri-v2-schema/refs/heads/main/tauri.conf.json",
  "productName": "Meeting Prompter",
  "version": "2.0.0",
  "identifier": "com.meetingprompter.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Meeting Prompter",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../runners/macos-arm64/*"
    ]
  }
}
